---
# C++ style for this project: LLVM base, 2-space indent, 100-col, right-aligned pointers,
# attached braces. Matches the existing hand-written style in src/main.cpp and the headers.
# include/lv_conf.h is intentionally NOT formatted (see .clang-format-ignore / .pre-commit-config.yaml).
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 2
ColumnLimit: 100
PointerAlignment: Right
DerivePointerAlignment: false
SortIncludes: false          # main.cpp orders <Arduino.h>/<lvgl.h> before local headers deliberately
AllowShortFunctionsOnASingleLine: Inline
KeepEmptyLinesAtTheStartOfBlocks: false
---
